# Fintech News Crawler - Environment Configuration Template
# Copy this file to .env.local in root directory and customize

# Application Environment
ENVIRONMENT=local
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql://admin:password@localhost:5432/fintech_data
POSTGRES_DB=fintech_data
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# Redis Configuration  
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# AI Models Configuration
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_CACHE_DIR=./models/finbert
GEMINI_API_KEY=your_gemini_api_key_here

# Storage Configuration (MinIO/S3)
STORAGE_TYPE=local
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=password
STORAGE_BUCKET=fintech-data

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=fintech_

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=structured
LOG_FILE=logs/application.log

# Crawler Settings
DEFAULT_RATE_LIMIT=60
MAX_RETRIES=3
RETRY_DELAY=5
REQUEST_TIMEOUT=30
USE_PROXY=false
BATCH_SIZE=16

# News Sources Configuration
NEWS_SOURCES=vnexpress,tuoitre,vietnamnet
MAX_ARTICLES_PER_SOURCE=100
CRAWL_INTERVAL_HOURS=2

# Processing Settings
SENTIMENT_BATCH_SIZE=32
ENABLE_GPU=false
GPU_DEVICE=0

# API Configuration (if running API server)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Security Settings
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=8080

# Email Notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@yourdomain.com 
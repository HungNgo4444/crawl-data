# -----------------------------------------------------------------------------
# Environment Variables Example
# -----------------------------------------------------------------------------
# This file serves as a template for the required environment variables.
# Copy this file to a new file named '.env' in the project root and fill in
# the actual values. The '.env' file is ignored by Git to keep secrets safe.
#
# Usage:
#   cp .env.example .env
#   Then, edit .env with your actual credentials.
# -----------------------------------------------------------------------------

# --- Database Configuration ---
# PostgreSQL connection string for the main application database.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
POSTGRES_DSN=postgresql://user:password@localhost:5432/app_db

# --- Redis Configuration ---
# Redis connection string for caching and background tasks.
# Format: redis://<host>:<port>/<db_number>
REDIS_DSN=redis://localhost:6379/0

# --- AI Services API Keys ---
# Your API key for Google Gemini for advanced text analysis.
# This is required for the AI-powered processing pipeline.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- MinIO (S3-Compatible Storage) Configuration ---
# Credentials for the local MinIO storage service defined in docker-compose.yml.
# These are used for storing raw scraped data (HTML, screenshots, etc.).
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=raw-data
MINIO_USE_SSL=False 
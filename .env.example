# Enhanced Crawler System - Environment Configuration
# Copy this file to .env and configure for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crawler_db
POSTGRES_USER=crawler_user
POSTGRES_PASSWORD=your_secure_password_here

# =============================================================================
# REDIS CONFIGURATION  
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# =============================================================================
# CRAWL4AI API KEYS (Required for LLM extraction)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_TOKEN=your_gemini_token_here

# Default LLM provider (optional)
LLM_PROVIDER=openai/gpt-3.5-turbo

# =============================================================================
# GOOGLE SEARCH API (For manual Google Search crawler)
# =============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cache settings
CACHE_TTL=86400
CACHE_DIR=./cache

# Performance settings
MAX_CONCURRENT_CRAWLS=10
MAX_URLS_PER_DOMAIN=1000
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=1.0

# =============================================================================
# OLLAMA CONFIGURATION (For Gwen3 analysis)
# =============================================================================
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
MODEL_NAME=qwen2.5:3b

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Secret key for session management
SECRET_KEY=your_super_secret_key_here_min_32_chars

# Admin credentials for Google Search manual triggers
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# JWT settings
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================
# Enable metrics collection
ENABLE_METRICS=true
METRICS_PORT=9090

# Health check settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# Docker image tags
CRAWL4AI_IMAGE_TAG=latest
WORKER_IMAGE_TAG=latest
POSTGRES_IMAGE_TAG=15-alpine
REDIS_IMAGE_TAG=7-alpine

# Resource limits (for Docker Compose)
CRAWL4AI_MEMORY_LIMIT=4G
WORKER_MEMORY_LIMIT=2G
POSTGRES_MEMORY_LIMIT=1G
REDIS_MEMORY_LIMIT=512M

# =============================================================================
# DEVELOPMENT SETTINGS (Development environment only)
# =============================================================================
# Enable development features
DEBUG=false
ENABLE_DEBUG_TOOLBAR=false
ENABLE_HOT_RELOAD=false

# Test database (for development)
TEST_DATABASE_URL=postgresql://crawler_user:crawler123@localhost:5433/crawler_test_db

# =============================================================================
# PRODUCTION SETTINGS (Production environment only) 
# =============================================================================
# SSL/TLS configuration
SSL_CERT_PATH=/etc/ssl/certs/crawler.crt
SSL_KEY_PATH=/etc/ssl/private/crawler.key

# Domain configuration
DOMAIN_NAME=crawler.yourdomain.com
ALLOWED_HOSTS=crawler.yourdomain.com,localhost,127.0.0.1

# Backup configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# Email notifications (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@yourdomain.com

# =============================================================================
# VIETNAMESE OPTIMIZATION SETTINGS
# =============================================================================
# Vietnamese content processing
ENABLE_VIETNAMESE_OPTIMIZATION=true
VIETNAMESE_CONTENT_THRESHOLD=0.5
VIETNAMESE_QUALITY_THRESHOLD=0.6

# Vietnamese text processing model
VIETNAMESE_NLP_MODEL=underthesea

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# HTTP client settings
HTTP_POOL_CONNECTIONS=100
HTTP_POOL_MAXSIZE=100
HTTP_POOL_BLOCK=false

# Asyncio settings
ASYNCIO_POLICY=uvloop  # uvloop for Linux, default for Windows

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
ENABLE_RSS_CRAWLING=true
ENABLE_SITEMAP_CRAWLING=true
ENABLE_CATEGORY_CRAWLING=true
ENABLE_GOOGLE_SEARCH_CRAWLING=false  # Manual trigger only
ENABLE_DEEP_CRAWLING_FALLBACK=true
ENABLE_CONTENT_EXTRACTION=true
ENABLE_VIETNAMESE_SCORING=true
ENABLE_DEDUPLICATION=true
ENABLE_CACHING=true
ENABLE_COMPRESSION=true

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit .env file to version control
# 2. Use strong passwords for production
# 3. Rotate API keys regularly  
# 4. Enable SSL/TLS for production deployments
# 5. Monitor resource usage and adjust limits accordingly
# 6. Backup your database regularly
# 7. Test configuration changes in staging first
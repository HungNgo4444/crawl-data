# -----------------------------------------------------------------------------
# Production Environment Variables Example
# -----------------------------------------------------------------------------
# Copy this file to .env and modify values for your production environment
# Usage: docker-compose -f docker-compose.production.yml --env-file .env up -d
# -----------------------------------------------------------------------------

# --- Database Configuration ---
POSTGRES_USER=crawler_user
POSTGRES_PASSWORD=crawler_123456
POSTGRES_DB=news_crawler_db
POSTGRES_PORT=5432

# --- Redis Configuration ---
REDIS_PORT=6379

# --- Crawler Configuration ---
CRAWLER_MODE=schedule
CRAWLER_INTERVAL=60

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Admin Interfaces ---
PGADMIN_EMAIL=admin@your-domain.com
PGADMIN_PASSWORD=your_pgadmin_password
PGADMIN_PORT=8080

# --- Monitoring ---
PORTAINER_PORT=9000

# --- Logging ---
LOG_LEVEL=INFO

# --- MinIO Configuration (Optional) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=raw-data
MINIO_USE_SSL=False
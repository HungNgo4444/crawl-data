# Test environment configuration
DEBUG=true
CRAWL_MODE=testing
LOG_LEVEL=DEBUG

# Test Database settings
DB_CONTAINER_NAME=test_postgres
DB_NAME=test_db
DB_USER=test_user
DB_PASSWORD=test123

# Mock external services for testing
NEWSPAPER4K_BASE_URL=http://mock-newspaper4k:8001
NEWSPAPER4K_TIMEOUT=5
NEWSPAPER4K_MAX_RETRIES=1

# Crawl4AI test settings
CRAWL4AI_BROWSER_TYPE=chromium
CRAWL4AI_HEADLESS=true
CRAWL4AI_STEALTH_MODE=false
CRAWL4AI_RATE_LIMIT=100
CRAWL4AI_TIMEOUT=5000

# Test queue settings
QUEUE_MAX_SIZE=100
QUEUE_BATCH_SIZE=5
QUEUE_MAX_CONCURRENT=1

# Test monitoring settings
MONITORING_INTERVAL=10
MONITORING_MAX_CONCURRENT=1

# Test deduplication settings
DEDUP_TTL_DAYS=1
DEDUP_CLEANUP_INTERVAL=1
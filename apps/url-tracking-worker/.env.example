# URL Tracking Worker Environment Configuration
# Copy this file to .env and modify as needed

# === Database Configuration (per CLAUDE.md) ===
DB_HOST=crawler_postgres
DB_PORT=5432
DB_USER=crawler_user
# DB_PASSWORD=your_secure_password  # REQUIRED - no default for security
DB_NAME=crawler_db

# === Connection Pool Settings ===
DB_MIN_CONNECTIONS=2
DB_MAX_CONNECTIONS=20

# === Core Scheduling ===
MONITORING_INTERVAL_MINUTES=15
MONITORING_TIMEOUT_SECONDS=840  # 14 minutes timeout

# === Processing Options ===
# Set USE_PURE_ASYNC=true for Option 2 (high performance)
# Set USE_PURE_ASYNC=false for Option 1 (timeout-based)
USE_PURE_ASYNC=false

# Concurrent processing settings
MAX_CONCURRENT_DOMAINS=15
BATCH_SIZE=500

# === Legacy Settings ===
MAX_WORKERS=4
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3

# === Features ===
LOG_LEVEL=INFO
ENABLE_LOGGING=true
ENABLE_GAP_DETECTION=true
ENABLE_SITEMAP_MONITORING=false

# === Quick Configurations ===
# Uncomment one of these for quick setup:

# Option 1: Timeout-based (safe, default)
# USE_PURE_ASYNC=false
# MAX_CONCURRENT_DOMAINS=10
# MONITORING_TIMEOUT_SECONDS=840

# Option 2: Pure Async (high performance)
# USE_PURE_ASYNC=true
# MAX_CONCURRENT_DOMAINS=20
# BATCH_SIZE=1000
# MONITORING_TIMEOUT_SECONDS=600